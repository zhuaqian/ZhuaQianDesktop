<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-4A5B-9C8D-7E6F5A4B3C2D}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>ZhuaQianDesktopApp</RootNamespace>
    <AssemblyName>ZhuaQianDesktop</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <LangVersion>7.3</LangVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Security" />
    <Reference Include="System.Web.Extensions" />
    <!-- First external NuGet dependency: headless Chromium for JS-rendered / login-gated pages.
         See docs/patches/BROWSER_RENDER_INTEGRATION.md. Adjust HintPath TFM if the installed
         package ships lib/net48 instead of lib/netstandard2.0. -->
    <Reference Include="Microsoft.Playwright">
      <HintPath>..\packages\Microsoft.Playwright.1.48.0\lib\netstandard2.0\Microsoft.Playwright.dll</HintPath>
    </Reference>
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml" />
  </ItemGroup>
  <!-- Self-syncing compile set: MSBuild globs every .cs under src/ so newly added
       modules are compiled automatically — no manual <Compile Include> registration.
       This removes the recurring "forgot to register in csproj" build break that
       build.ps1 / run-tests.ps1 already avoided via dynamic enumeration.
       Exclusions mirror the build scripts:
         - Program.cs / MainForm.cs / TaskInfo.cs : duplicate entry points / types
           (CS0017 / CS0262 / CS0101); the production EXE builds from ZhuaQianDesktop.cs.
         - tests/** : unit tests compile + run via src/scripts/run-tests.ps1 (/main:TestRunner);
           kept out of the shipped EXE to avoid multiple entry points (CS0017).
         - packages/** : NuGet restore output, not source. -->
  <ItemGroup>
    <Compile Include="**\*.cs" Exclude="Program.cs;MainForm.cs;TaskInfo.cs;tests\**;packages\**" />
  </ItemGroup>
  <!-- Unit tests are compiled and run via src/scripts/run-tests.ps1 (csc + /main:TestRunner),
       NOT via this csproj. Keeping them out of the shipped EXE avoids multiple entry points
       (CS0017) and prevents test code from being packaged into the release binary. -->
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
