# Build output (produced by build.ps1)
/dist/
/bin/
/obj/
/generated/
/build/

# Generated release packages — regenerate from src/, do not commit
/outputs/

# Local dev / CI build zips
*-local-dev.zip
*.zip

# User-specific IDE/tooling
*.user
*.suo
*.userprefs
.vs/

# OS clutter
Thumbs.db
ehthumbs.db
Desktop.ini

# NuGet packages (restored by nuget restore, never commit)
src/packages/

# Logs
*.log

# Local secrets / environment
.env
.env.*
secret*.json

# Local agent memory / project notes (not for the public repo)
.workbuddy/

# Build artifacts (produced by build.ps1 / csc; never commit)
*.exe
*.pdb
